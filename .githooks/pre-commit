#!/bin/sh

echo "==> Running Git pre-commit secrets check..."

# Run gitleaks detect on the directory
gitleaks detect --no-git --source . --verbose --redact
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo "\n🔴 COMMIT BLOCKED: Leaked secrets detected by Gitleaks!"
  exit $EXIT_CODE
fi

echo "\n==> Running Python static builder expect tests..."
python test_build.py
TEST_CODE=$?

if [ $TEST_CODE -ne 0 ]; then
  echo "\n🔴 COMMIT BLOCKED: Python expect tests failed!"
  exit $TEST_CODE
fi

echo "\n✨ All checks passed. Proceeding with commit..."
exit 0
